#!/usr/bin/env bash
# pre-command hook: runs before each command step
# Sets up environment variables and tooling required for the build

set -euo pipefail

echo "--- :buildkite: Setting up build environment"

# Determine the Go version from the go.mod file if present
if [[ -f "go.mod" ]]; then
  GO_VERSION=$(grep '^go ' go.mod | awk '{print $2}')
  echo "Detected Go version from go.mod: ${GO_VERSION}"
  export GO_VERSION
fi

# Set common build environment variables
export BUILDKITE_BUILD_AUTHOR_EMAIL="${BUILDKITE_BUILD_AUTHOR_EMAIL:-ci@authelia.com}"
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

# Configure git safe directory for the checkout
git config --global --add safe.directory "${BUILDKITE_BUILD_CHECKOUT_PATH}"

# Print useful debug information
echo "--- :information_source: Build Information"
echo "  Branch:    ${BUILDKITE_BRANCH:-unknown}"
echo "  Commit:    ${BUILDKITE_COMMIT:-unknown}"
echo "  Build:     ${BUILDKITE_BUILD_NUMBER:-unknown}"
echo "  Pipeline:  ${BUILDKITE_PIPELINE_SLUG:-unknown}"

# Determine if this is a tagged release
if [[ -n "${BUILDKITE_TAG:-}" ]]; then
  echo "  Tag:       ${BUILDKITE_TAG}"
  export TAGGED_RELEASE=true
else
  export TAGGED_RELEASE=false
fi

# Determine if this is a pull request build
if [[ -n "${BUILDKITE_PULL_REQUEST:-}" && "${BUILDKITE_PULL_REQUEST}" != "false" ]]; then
  echo "  PR:        #${BUILDKITE_PULL_REQUEST}"
  export IS_PULL_REQUEST=true
else
  export IS_PULL_REQUEST=false
fi

echo "--- :white_check_mark: Build environment configured successfully"
